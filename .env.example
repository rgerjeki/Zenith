# Copy to `.env` and fill in. Never commit your real .env.
# Used server-side only, by the /api functions. Never exposed to the browser.

# Google Gemini API key (free tier is fine).
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-key-here

# Optional: override the model. Defaults to gemini-3.5-flash (current stable
# Flash). Note: gemini-2.5-flash is retired for new API keys.
# GEMINI_MODEL=gemini-3.5-flash

# ElevenLabs (optional). Narrates the briefings aloud. Without a key, the app
# just stays silent. Get one at https://elevenlabs.io.
ELEVENLABS_API_KEY=your-key-here
# Optional. If unset, a voice your account can use is auto-discovered (free
# accounts can't use shared "library" voices via the API). Set this to a voice
# you own to force a specific one.
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2
