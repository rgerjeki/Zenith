# Copy to `.env` and fill in. Never commit your real .env.
# Used server-side only, by /api/briefing.js — never exposed to the browser.

# Google Gemini API key (free tier is fine).
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-key-here

# Optional: override the model. Defaults to gemini-2.5-flash (free-tier, GA).
# Newer options as of 2026 include gemini-3.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# ElevenLabs — optional. Narrates the briefings aloud (a warm voice reads you
# the sky). Without a key, the app just stays silent. Get one at elevenlabs.io.
ELEVENLABS_API_KEY=your-key-here
# Optional overrides:
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_multilingual_v2
